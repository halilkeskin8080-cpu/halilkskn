<!DOCTYPE html>
<html lang="tr">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Alışveriş Tablosu</title>
<style>
  table {
    width: 50%;
    border-collapse: collapse;
    text-align: center;
    margin: 20px auto;
  }
  th, td {
    border: 1px solid black;
    padding: 10px;
  }
</style>
</head>
<body>

<h2 style="text-align: center;">Alış Veriş Tablosu</h2>
<table>
  <tr>
    <th>Tür</th>
    <th>Ürün</th>
    <th>Fiyat</th>
    <th>İndirim Oranı</th>
  </tr>
  <tr>
    <td rowspan="5">Beyaz Eşya</td>
    <td>Buzdolabı</td>
    <td>1.750</td>
    <td></td>
  </tr>
  <tr>
    <td>Fırın</td>
    <td>650</td>
    <td>%25</td>
  </tr>
  <tr>
    <td>Çamaşır Makinesi</td>
    <td>1.100</td>
    <td></td>
  </tr>
  <tr>
    <td>Bulaşık Makinesi</td>
    <td>750</td>
    <td>%35</td>
  </tr>
  <tr>
    <td>Dondurucu</td>
    <td>600</td>
    <td></td>
  </tr>
  <tr>
    <td rowspan="2">Küçük Ev Aletleri</td>
    <td>Mikser</td>
    <td>138</td>
    <td>%10</td>
  </tr>
  <tr>
    <td>Saç Kurutma</td>
    <td>151</td>
    <td></td>
  </tr>
</table>

</body>
</html>