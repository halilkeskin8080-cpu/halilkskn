    function editEmployee(id) {
      const emp = employees.find(e => e.__backendId === id);
      if (emp) openModal(emp);
    }

    function updateStats() {
      document.getElementById('total-count').textContent = employees.length;
      document.getElementById('active-count').textContent = employees.filter(e => e.status === 'Aktif').length;
      
      const uniqueDepts = new Set(employees.map(e => e.department));
      document.getElementById('department-count').textContent = uniqueDepts.size;

      const thisMonth = new Date().getMonth();
      const thisYear = new Date().getFullYear();
      const monthCount = employees.filter(e => {
        const startDate = new Date(e.start_date);
        return startDate.getMonth() === thisMonth && startDate.getFullYear() === thisYear;
      }).length;
      document.getElementById('month-count').textContent = monthCount;
    }

    function updateLimitWarning() {
      const warning = document.getElementById('limit-warning');
      if (employees.length >= 999) {
        warning.classList.remove('hidden');
      } else {
        warning.classList.add('hidden');
      }
    }

    function setFormLoading(loading) {
      const btn = document.getElementById('save-btn');
      const btnText = document.getElementById('save-button-text');
      
      if (loading) {
        btn.disabled = true;
        btn.classList.add('opacity-70');
        btnText.innerHTML = '<div class="loading-spinner mr-2"></div>Kaydediliyor...';
      } else {
        btn.disabled = false;
        btn.classList.remove('opacity-70');
        btnText.textContent = window.elementSdk ? window.elementSdk.config.save_button_text || defaultConfig.save_button_text : defaultConfig.save_button_text;
      }
    }

    function showFormMessage(text, type) {
      const message = document.getElementById('form-message');
      message.className = `mt-4 px-4 py-3 rounded-xl text-sm font-medium ${
        type === 'success' 
          ? 'bg-green-500/20 text-green-300 border border-green-500/40' 
          : 'bg-red-500/20 text-red-300 border border-red-500/40'
      }`;
      message.textContent = text;
      message.classList.remove('hidden');

      if (type === 'success') {
        setTimeout(() => {
          message.classList.add('hidden');
        }, 3000);
      }
    }

    window.editEmployee = editEmployee;
    window.openDeleteModal = openDeleteModal;

